@model ContosoUniversity.Models.Instructor

@{
    ViewBag.Title = "Instructor Details";
}

<h2 class="mb-4">Instructor Details</h2>

<div class="card shadow-sm border-0 rounded-3 p-4">

    <h4 class="card-title mb-3">Instructor Information</h4>
    <hr />

    <dl class="row">

        <!-- Office Location -->
        <dt class="col-sm-3 fw-bold">Office Location</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.OfficeAssignment.Location)</dd>

        <!-- Last Name -->
        <dt class="col-sm-3 fw-bold">Last Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.LastName)</dd>

        <!-- FirstMidName -->
        <dt class="col-sm-3 fw-bold">First / Middle Name</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.FirstMidName)</dd>

        <!-- HireDate -->
        <dt class="col-sm-3 fw-bold">Hire Date</dt>
        <dd class="col-sm-9">@Html.DisplayFor(m => m.HireDate)</dd>

    </dl>

</div>

<div class="mt-3">
    @Html.ActionLink("Edit", "Edit", new { id = Model.ID }, new { @class = "btn btn-primary me-2" })
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
</div>
