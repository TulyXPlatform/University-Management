@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Edit Course";
}

<!-- Page Header -->
<div class="text-white text-center py-4 mb-4" style="background-color:#1b3b2d;">
    <h2 class="fw-bold">Edit Course</h2>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="container" style="max-width:700px;">
        <div class="card border-0" style="background-color:#f5f0e1;">
            <div class="card-body">

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                @Html.HiddenFor(model => model.CourseID)

                <!-- Course ID -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Course ID</label>
                    <div class="form-control-plaintext">
                        @Html.DisplayFor(model => model.CourseID)
                    </div>
                </div>

                <!-- Title -->
                <div class="mb-3">
                    @Html.LabelFor(model => model.Title, new { @class = "form-label fw-bold" })
                    @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                </div>

                <!-- Credits -->
                <div class="mb-3">
                    @Html.LabelFor(model => model.Credits, new { @class = "form-label fw-bold" })
                    @Html.EditorFor(model => model.Credits, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Credits, "", new { @class = "text-danger" })
                </div>

                <!-- Department -->
                <div class="mb-4">
                    @Html.LabelFor(model => model.DepartmentID, "Department", new { @class = "form-label fw-bold" })
                    @Html.DropDownList("DepartmentID", null, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.DepartmentID, "", new { @class = "text-danger" })
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end">
                    <input type="submit" value="Save"
                           class="btn"
                           style="background-color:#1b3b2d; color:#f5f0e1;" />

                    @Html.ActionLink("Back to List", "Index", null,
                        new { @class = "btn btn-secondary ms-2" })
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
