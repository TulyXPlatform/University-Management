@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Delete";
}

<h2 class="text-danger">Delete Course</h2>

<h4>Are you sure you want to delete this course?</h4>
<hr />

<dl class="dl-horizontal">
    <dt>Department</dt>
    <dd>@Html.DisplayFor(model => model.Department.Name)</dd>

    <dt>Course ID</dt>
    <dd>@Html.DisplayFor(model => model.CourseID)</dd>

    <dt>Title</dt>
    <dd>@Html.DisplayFor(model => model.Title)</dd>

    <dt>Credits</dt>
    <dd>@Html.DisplayFor(model => model.Credits)</dd>
</dl>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-actions">
        <input type="submit" value="Delete" class="btn btn-danger" />
        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}
