@model ContosoUniversity.Models.Course

@{
    ViewBag.Title = "Course Details";
}

<!-- Page Header -->
<div class="text-white text-center py-4 mb-4" style="background-color:#1b3b2d;">
    <h2 class="fw-bold">Course Details</h2>
</div>

<div class="container" style="max-width:700px;">
    <div class="card shadow-sm border-0" style="background-color:#f5f0e1;">
        <div class="card-body">

            <h4 class="mb-3">Course Information</h4>
            <hr />

            <dl class="row">

                <!-- Department -->
                <dt class="col-sm-4 fw-bold">Department</dt>
                <dd class="col-sm-8">@Model.Department.Name</dd>

                <!-- Title -->
                <dt class="col-sm-4 fw-bold">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>

                <!-- Credits -->
                <dt class="col-sm-4 fw-bold">Credits</dt>
                <dd class="col-sm-8">@Model.Credits</dd>

            </dl>
        </div>

        <div class="card-footer d-flex justify-content-end" style="background-color:#f5f0e1;">
            <a href="@Url.Action("Edit", new { id = Model.CourseID })"
               class="btn"
               style="background-color:#1b3b2d; color:#f5f0e1;">Edit</a>

            <a href="@Url.Action("Index")"
               class="btn btn-secondary ms-2">Back to List</a>
        </div>
    </div>
</div>
