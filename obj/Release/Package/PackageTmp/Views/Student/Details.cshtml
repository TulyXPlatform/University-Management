@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Student Details";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-3">

        <div class="card-header bg-primary text-white py-3 rounded-top">
            <h4 class="mb-0">Student Details</h4>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- Picture -->
                <div class="col-md-4 text-center mb-4">
                    @if (Model.PictureData != null)
                    {
                        <img src="@Url.Action("GetImage", new { id = Model.ID })"
                             class="img-fluid rounded-circle border"
                             style="max-width: 180px;" />
                    }
                    else
                    {
                        <div class="text-muted fst-italic">No image available</div>
                    }
                </div>

                <!-- Main Info -->
                <div class="col-md-8">

                    <table class="table table-borderless">

                        <tr>
                            <th class="text-muted" width="180">Status</th>
                            <td>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success px-3 py-2">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2">Inactive</span>
                                }
                            </td>
                        </tr>

                        <tr>
                            <th class="text-muted">Last Name</th>
                            <td>@Html.DisplayFor(m => m.LastName)</td>
                        </tr>

                        <tr>
                            <th class="text-muted">First / Middle Name</th>
                            <td>@Html.DisplayFor(m => m.FirstMidName)</td>
                        </tr>

                        <tr>
                            <th class="text-muted">Enrollment Date</th>
                            <td>@Html.DisplayFor(m => m.EnrollmentDate)</td>
                        </tr>

                    </table>

                </div>
            </div>

            <!-- Enrollments -->
            <div class="mt-4">

                <h5 class="fw-bold mb-3">Enrollments</h5>

                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Course Title</th>
                            <th>Grade</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Enrollments)
                        {
                            <tr>
                                <td>@item.Course.Title</td>
                                <td>@item.Grade</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-end mt-4">
                @Html.ActionLink("Edit", "Edit", new { id = Model.ID }, new { @class = "btn btn-primary me-2" })
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
            </div>

        </div>

    </div>
</div>
