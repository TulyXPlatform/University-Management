@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Create Student";
}

<!-- Header -->
<div class="text-white text-center py-4 mb-4" style="background-color:#1b3b2d;">
    <h1 class="fw-bold" style="font-size:2.2rem;">Add New Student</h1>
    <p class="mb-0">Fill the form to register a student</p>
</div>

<div class="container">

    <div class="card shadow border-0 rounded-3">
        <div class="card-header text-white py-3" style="background-color:#2f5b44;">
            <h5 class="mb-0">Create Student</h5>
        </div>

        <div class="card-body">

            @using (Html.BeginForm("Create", "Student", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                <div class="row">

                    <!-- Last Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Last Name</label>
                        @Html.TextBoxFor(m => m.LastName,
                            new { @class = "form-control", placeholder = "Enter last name" })
                        @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
                    </div>

                    <!-- First / Middle Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">First / Middle Name</label>
                        @Html.TextBoxFor(m => m.FirstMidName,
                            new { @class = "form-control", placeholder = "Enter first or middle name" })
                        @Html.ValidationMessageFor(m => m.FirstMidName, "", new { @class = "text-danger" })
                    </div>

                    <!-- Enrollment Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Enrollment Date</label>
                        @Html.EditorFor(m => m.EnrollmentDate,
                            new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(m => m.EnrollmentDate, "", new { @class = "text-danger" })
                    </div>

                    <!-- Image Upload -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Profile Picture</label>
                        <input type="file" name="image" accept="image/*" class="form-control" />
                    </div>

                    <!-- Is Active -->
                    <div class="col-md-12 mt-2 mb-3">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" })
                            <label class="form-check-label fw-bold ms-1">Active</label>
                        </div>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="text-end mt-3">
                    <button type="submit" class="btn px-4"
                            style="background-color:#1b3b2d; color:#f5f0e1;">
                        Create
                    </button>

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary ms-2 px-4">
                        Back to List
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

<style>
    .btn:hover {
        opacity: 0.85;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.15rem rgba(27, 59, 45, 0.35);
        border-color: #1b3b2d;
    }
</style>
