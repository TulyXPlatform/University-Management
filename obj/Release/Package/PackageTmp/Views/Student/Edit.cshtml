@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Edit Student";
}

<!-- Header -->
<div class="text-white text-center py-4 mb-4" style="background-color:#1b3b2d;">
    <h1 class="fw-bold" style="font-size:2.2rem;">Edit Student</h1>
    <p class="mb-0">Update student details</p>
</div>

<div class="container">

    <div class="card shadow border-0 rounded-3">
        <div class="card-header text-white py-3" style="background-color:#2f5b44;">
            <h5 class="mb-0">Edit Student Information</h5>
        </div>

        <div class="card-body">

            @using (Html.BeginForm("Edit", "Student", FormMethod.Post,
                       new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                @Html.HiddenFor(model => model.ID)

                <div class="row">

                    <!-- Last Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Last Name</label>
                        @Html.EditorFor(model => model.LastName,
                            new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger" })
                    </div>

                    <!-- First / Middle Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">First / Middle Name</label>
                        @Html.EditorFor(model => model.FirstMidName,
                            new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.FirstMidName, "", new { @class = "text-danger" })
                    </div>

                    <!-- Enrollment Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Enrollment Date</label>
                        @Html.EditorFor(model => model.EnrollmentDate,
                            new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.EnrollmentDate, "", new { @class = "text-danger" })
                    </div>

                    <!-- Current Picture -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Current Picture</label><br />

                        @if (Model.PictureData != null)
                        {
                            <img src="@Url.Action("GetImage", "Student", new { id = Model.ID })"
                                 class="img-thumbnail shadow-sm"
                                 style="width:120px; height:120px; object-fit:cover; border-radius:6px;" />
                        }
                        else
                        {
                            <p class="text-muted">No image uploaded.</p>
                        }
                    </div>

                    <!-- Upload New Picture -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Upload New Picture</label>
                        <input type="file" name="image" accept="image/*" class="form-control" />
                        <span class="text-muted">Leave blank to keep current picture.</span>
                    </div>

                    <!-- Is Active -->
                    <div class="col-md-12 mt-2 mb-2">
                        <div class="form-check">
                            @Html.CheckBoxFor(model => model.IsActive,
                                new { @class = "form-check-input" })
                            <label class="form-check-label fw-bold ms-1">Active</label>
                        </div>
                    </div>

                </div>

                <!-- Action Buttons -->
                <div class="text-end mt-3">
                    <button type="submit" class="btn px-4"
                            style="background-color:#1b3b2d; color:#f5f0e1;">
                        Save Changes
                    </button>

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary ms-2 px-4">
                        Back to List
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

<style>
    .btn:hover {
        opacity: 0.85;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.15rem rgba(27, 59, 45, 0.35);
        border-color: #1b3b2d;
    }
</style>
