@model ContosoUniversity.Models.Student

@{
    ViewBag.Title = "Delete Student";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-3">

        <div class="card-header bg-danger text-white py-3 rounded-top">
            <h4 class="mb-0">Delete Student</h4>
        </div>

        <div class="card-body">

            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            <h5 class="text-danger fw-bold mb-3">Are you sure you want to delete this student?</h5>

            <table class="table table-borderless">

                <tr>
                    <th class="text-muted" width="180">Last Name</th>
                    <td>@Html.DisplayFor(model => model.LastName)</td>
                </tr>

                <tr>
                    <th class="text-muted">First / Middle Name</th>
                    <td>@Html.DisplayFor(model => model.FirstMidName)</td>
                </tr>

                <tr>
                    <th class="text-muted">Enrollment Date</th>
                    <td>@Html.DisplayFor(model => model.EnrollmentDate)</td>
                </tr>

            </table>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mt-4 d-flex justify-content-end">

                    <input type="submit"
                           value="Delete"
                           class="btn btn-danger me-2 px-4" />

                    @Html.ActionLink("Back to List",
                        "Index",
                        null,
                        new { @class = "btn btn-secondary px-4" })
                </div>
            }

        </div>

    </div>

</div>
