@model ContosoUniversity.Models.Department

@{
    ViewBag.Title = "Create Department";
}

<h2 class="mb-4">Create Department</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm p-4 border-0 rounded-3">

        <h4 class="card-title mb-3">Department Information</h4>
        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        <!-- Name -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Name, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.Name, new { @class = "form-control", placeholder = "Enter department name" })
            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
        </div>

        <!-- Budget -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Budget, new { @class = "form-label fw-bold" })
            @Html.EditorFor(model => model.Budget, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter budget amount" } })
            @Html.ValidationMessageFor(model => model.Budget, "", new { @class = "text-danger" })
        </div>

        <!-- Start Date -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.StartDate, new { @class = "form-label fw-bold" })
            @Html.EditorFor(model => model.StartDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.StartDate, "", new { @class = "text-danger" })
        </div>

        <!-- Administrator -->
        <div class="form-group mb-4">
            @Html.LabelFor(model => model.InstructorID, "Administrator", new { @class = "form-label fw-bold" })
            @Html.DropDownList("InstructorID", null, new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.InstructorID, "", new { @class = "text-danger" })
        </div>

        <!-- Submit Button -->
        <div class="text-end">
            <input type="submit" value="Create Department" class="btn btn-primary px-4" />
        </div>

    </div>
}

<div class="mt-3">
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
