@model ContosoUniversity.Models.Department

@{
    ViewBag.Title = "Edit";
}

<h2>Edit Department</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(model => model.DepartmentID)
    @Html.HiddenFor(model => model.RowVersion)

    <div class="card shadow-sm border-0 rounded-3 p-4">

        <h4 class="mb-3">Department Details</h4>
        <hr />

        <!-- Name -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Name, new { @class = "control-label" })
            @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
        </div>

        <!-- Budget -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.Budget, new { @class = "control-label" })
            @Html.EditorFor(model => model.Budget, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Budget, "", new { @class = "text-danger" })
        </div>

        <!-- Start Date -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.StartDate, new { @class = "control-label" })
            @Html.EditorFor(model => model.StartDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.StartDate, "", new { @class = "text-danger" })
        </div>

        <!-- Administrator -->
        <div class="form-group mb-3">
            @Html.Label("InstructorID", "Administrator", new { @class = "control-label" })
            @Html.DropDownList("InstructorID", null, new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.InstructorID, "", new { @class = "text-danger" })
        </div>

        <!-- Buttons -->
        <div class="form-group mt-4">
            <input type="submit" value="Save" class="btn btn-default" />
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default ms-2" })
        </div>

    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
