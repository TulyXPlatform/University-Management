@model IEnumerable<ContosoUniversity.Models.Course>

@{
    ViewBag.Title = "Courses";
}

<!-- Page Header -->
<div class="text-white text-center py-4 mb-4" style="background-color:#1b3b2d;">
    <h1 class="fw-bold" style="font-size:2.2rem;">Course Management</h1>
    <p class="mb-0">Overview of courses and departments</p>
</div>

<div class="container">

    <!-- Create Button -->
    <div class="text-end mb-3">
        <a href="@Url.Action("Create")"
           class="btn btn-lg"
           style="background-color:#2f5b44; color:#f5f0e1;">
            + Add Course
        </a>
    </div>

    <!-- Department Filter -->
    @using (Html.BeginForm())
    {
        <div class="mb-3 d-flex align-items-center">
            <label class="me-2 fw-bold">Select Department:</label>
            @Html.DropDownList("SelectedDepartment",
                ViewBag.SelectedDepartment as SelectList,
                "All",
                new { @class = "form-select w-auto me-2" })
            <input type="submit" value="Filter"
                   class="btn btn-sm"
                   style="background-color:#1b3b2d; color:#f5f0e1;" />
        </div>
    }

    <!-- Course Table -->
    <div class="card shadow border-0">
        <div class="card-header text-white py-2" style="background-color:#2f5b44;">
            <h5 class="mb-0">Courses</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0" style="background-color:#f5f0e1;">
                <thead style="background-color:#1b3b2d; color:white;">
                    <tr>
                        <th>Course ID</th>
                        <th>Title</th>
                        <th>Credits</th>
                        <th>Department</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="vertical-align:middle;">
                            <td>@item.CourseID</td>
                            <td>@item.Title</td>
                            <td>@item.Credits</td>
                            <td>@item.Department.Name</td>
                            <td class="text-center">
                                <a href="@Url.Action("Edit", new { id = item.CourseID })"
                                   class="btn btn-sm"
                                   style="background-color:#1b3b2d; color:#f5f0e1;">Edit</a>

                                <a href="@Url.Action("Details", new { id = item.CourseID })"
                                   class="btn btn-sm btn-secondary">Details</a>

                                <a href="@Url.Action("Delete", new { id = item.CourseID })"
                                   class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Hover Effects -->
<style>
    .table-hover tbody tr:hover {
        background-color: #e7e2d3;
        transition: 0.2s;
    }

    .btn:hover {
        opacity: 0.85;
    }

    .form-select:focus {
        border-color: #2f5b44;
        box-shadow: 0 0 0 0.2rem rgba(47, 91, 68, 0.25);
    }
</style>
