@{
    ViewBag.Title = "Contact";
}

<main aria-labelledby="title" class="py-5" style="background-color:#f5f0e1; min-height:70vh;">
    <div class="container py-4">

        <h2 id="title" class="mb-4" style="color:#1b3b2d;">
            @ViewBag.Title
        </h2>

        <p class="lead mb-5" style="color:#3a4a40;">
            @ViewBag.Message
        </p>

        <div class="row">

            <!-- Contact Address -->
            <div class="col-md-6 mb-4">
                <div class="p-4 shadow-sm rounded" style="background-color:#ffffff; border-left:5px solid #1b3b2d;">
                    <h4 style="color:#1b3b2d;">Our Office</h4>
                    <p class="mt-3 text-dark">
                        One Microsoft Way<br />
                        Redmond, WA 98052-6399
                    </p>

                    <p class="text-dark">
                        <strong>Phone:</strong> 425.555.0100
                    </p>
                </div>
            </div>

            <!-- Email Contacts -->
            <div class="col-md-6 mb-4">
                <div class="p-4 shadow-sm rounded" style="background-color:#ffffff; border-left:5px solid #1b3b2d;">
                    <h4 style="color:#1b3b2d;">Connect With Us</h4>

                    <p class="mt-3">
                        <strong>Support:</strong>
                        <a href="mailto:tamima.web5202@gmail.com" style="color:#1b3b2d;">
                            tamima.web5202@gmail.com
                        </a>
                    </p>

                    <p>
                        <strong>Marketing:</strong>
                        <a href="mailto:tamima.web5202@gmail.com" style="color:#1b3b2d;">
                            Marketing@example.com
                        </a>
                    </p>
                </div>
            </div>
        </div>

    </div>
</main>
