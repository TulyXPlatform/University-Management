<!-- Back to Top Button -->
<button id="backToTop" title="Go to top">&#8679;</button>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $('a.nav-link[href^="#"]').click(function (e) {
            e.preventDefault();
            var target = $(this.hash);
            $('html, body').animate({ scrollTop: target.offset().top - 70 }, 700);
        });

        var btn = $('#backToTop');
        $(window).scroll(function () {
            if ($(window).scrollTop() > 300) { btn.fadeIn(); } else { btn.fadeOut(); }
        });
        btn.click(function () { $('html, body').animate({ scrollTop: 0 }, 700); });
    });
</script>

<!-- Styles -->
<style>

    .hero-section {
        position: relative;
        padding: 180px 20px;
        background-image: url('/Content/images/hero.jpg');
        /* background image path */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed; /* creates parallax effect */
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .hero-section::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(27, 59, 45, 0.6); /* overlay for text readability */
            background: linear-gradient( rgba(27,59,45,0.75), rgba(27,59,45,0.85) );
            z-index: 1;
        }

        .hero-section .hero-content {
            position: relative;
            z-index: 2;
        }

    section {
        border-bottom: 1px solid #ddd;
    }

    header {
        background: linear-gradient(135deg, #1b3b2d, #2f5b44);
    }

    #backToTop {
        display: none;
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 99;
        font-size: 24px;
        background: #f5f0e1;
        color: #1b3b2d;
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        cursor: pointer;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
    }

        #backToTop:hover {
            background: #e0d8c0;
        }

    .card {
        transition: transform 0.6s, opacity 0.6s;
        opacity: 1;
        transform: translate(0,0);
    }

</style>
