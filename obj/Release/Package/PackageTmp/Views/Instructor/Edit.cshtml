@model ContosoUniversity.Models.Instructor

@{
    ViewBag.Title = "Edit Instructor";
}

<h2 class="mb-4">Edit Instructor</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm p-4">
        <h4 class="card-title mb-3">Instructor Details</h4>
        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
        @Html.HiddenFor(model => model.ID)

        <!-- Last Name -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.LastName, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.LastName, new { @class = "form-control", placeholder = "Enter last name" })
            @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger" })
        </div>

        <!-- FirstMidName -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.FirstMidName, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.FirstMidName, new { @class = "form-control", placeholder = "Enter first/middle name" })
            @Html.ValidationMessageFor(model => model.FirstMidName, "", new { @class = "text-danger" })
        </div>

        <!-- Hire Date -->
        <div class="form-group mb-3">
            @Html.LabelFor(model => model.HireDate, new { @class = "form-label fw-bold" })
            @Html.EditorFor(model => model.HireDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.HireDate, "", new { @class = "text-danger" })
        </div>

        <!-- Office Location -->
        <div class="form-group mb-4">
            @Html.LabelFor(model => model.OfficeAssignment.Location, new { @class = "form-label fw-bold" })
            @Html.TextBoxFor(model => model.OfficeAssignment.Location, new { @class = "form-control", placeholder = "Office location" })
            @Html.ValidationMessageFor(model => model.OfficeAssignment.Location, "", new { @class = "text-danger" })
        </div>

        <!-- Assigned Courses -->
        <h5 class="fw-bold mt-4 mb-2">Assigned Courses</h5>
        <div class="p-3 border rounded bg-light mb-4">

            <div class="row">
                @{
                    List<ContosoUniversity.ViewModels.AssignedCourseData> courses = ViewBag.Courses;
                    foreach (var course in courses)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       name="selectedCourses"
                                       value="@course.CourseID"
                                       @(course.Assigned ? "checked" : "") />

                                <label class="form-check-label">
                                    <strong>@course.CourseID</strong> - @course.Title
                                </label>
                            </div>
                        </div>
                    }
                }
            </div>

        </div>

        <!-- Save Button -->
        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">Save Changes</button>
        </div>

    </div>
}

<div class="mt-3">
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
